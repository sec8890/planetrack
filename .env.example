PORT=3000
# OpenSky anonymous access easily supports this cadence (a full-globe poll
# costs 4 credits against a 400-credit/day anonymous budget)
REFRESH_MINUTES=15

# Optional: register a free account at https://opensky-network.org/my-opensky/account
# and create an API client to get these. Authenticated requests get a much
# higher daily budget and finer time resolution than anonymous access.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
